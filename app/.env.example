# TMDB v3 read-only API key (safe in client; TMDB explicitly supports this).
EXPO_PUBLIC_TMDB_KEY=

# Supabase project — created in Phase 1.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Google OAuth client ID for Sign in with Google.
# Apple Sign In needs no client-side key.
EXPO_PUBLIC_GOOGLE_CLIENT_ID=
